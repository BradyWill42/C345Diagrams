        <mxCell id="JOoKk0994VdbTXqO4fU7-5" connectable="0" parent="1" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontFamily=Helvetica;fontSize=11;fontColor=default;labelBackgroundColor=default;" value="44.36.16.1/24" vertex="1">
